# Copy to .env in repository root and fill with real values
# PowerShell: Copy-Item .env.example .env

# Root env used by docker-compose
POSTGRES_PASSWORD=postgres
JWT_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:8080

# Backend
SENDGRID_API_KEY=SG_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=no-reply@tu-dominio.com
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Monitoring and alerts
MONITOR_ALERT_EMAIL_TO=
MONITOR_ALERT_WEBHOOK_URL=
MONITOR_DB_LATENCY_MS_THRESHOLD=500
OBSERVABILITY_BIND_HOST=127.0.0.1

# Backup retention
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=7

# Docker container log rotation
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Observability access proxy
OBSERVABILITY_BASIC_AUTH_USER=admin
OBSERVABILITY_BASIC_AUTH_PASSWORD=change-me
